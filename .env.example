PORT=4000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/?appName=Cluster0

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate-a-random-64-byte-hex-string>

# Cloudflare R2 Object Storage
# Account ID: Cloudflare dashboard → right sidebar
# Access Key ID + Secret: R2 → Manage R2 API Tokens → Create API Token
CF_R2_ACCOUNT_ID=<cloudflare-account-id>
CF_R2_ACCESS_KEY_ID=<r2-access-key-id>
CF_R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
CF_R2_BUCKET_NAME=<bucket-name>
# Optional: custom domain or r2.dev public URL for the bucket
CF_R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Paystack
PAYSTACK_SECRET_KEY=<sk_live_or_sk_test_key>

# Firebase Admin SDK
FIREBASE_PROJECT_ID=<project-id>
FIREBASE_CLIENT_EMAIL=<service-account>@<project-id>.iam.gserviceaccount.com
# Paste the private key with literal \n — do not use real newlines inside quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<key-data>\n-----END PRIVATE KEY-----\n"

# Redis (optional — for rate limiting and token revocation)
# REDIS_URL=rediss://<user>:<password>@<host>:<port>
